# Telegram API — получить на https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_PHONE=          # ваш номер телефона, например +79001234567

# Канал — username без @ или числовой ID
TG_CHANNEL=        # например: my_channel_name

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=   # service_role key (не anon!)
SUPABASE_BUCKET=day-pins  # название bucket в Storage
